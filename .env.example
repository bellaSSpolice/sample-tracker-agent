# Database (Railway PostgreSQL)
DATABASE_URL=postgresql://user:password@host:port/dbname

# Gmail OAuth2 (base64-encoded JSON files)
GMAIL_OAUTH_CREDENTIALS=<base64-encoded credentials.json>
GMAIL_OAUTH_TOKEN=<base64-encoded token.json>
GMAIL_ADDRESS=hello@sleepysaturday.com

# Ship24 API
SHIP24_API_KEY=apik_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Flask
FLASK_SECRET_KEY=change-me-to-a-random-string

# Manual trigger endpoint auth
TRIGGER_SECRET_KEY=change-me-to-a-random-string

# Scheduler intervals (hours)
SCAN_INTERVAL_HOURS=2
STATUS_CHECK_INTERVAL_HOURS=2
